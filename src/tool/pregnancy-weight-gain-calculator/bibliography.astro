---
import { Bibliography as BibliographyUI } from "@jjlmoya/utils-shared";
import { pregnancyWeightGainCalculator } from "./index";
import type { KnownLocale } from "../../types";

interface Props {
  locale?: KnownLocale;
}

const { locale = "en" } = Astro.props;
const content = await pregnancyWeightGainCalculator.i18n[locale]?.();
if (!content) return null;
---

<BibliographyUI links={content.bibliography} />
