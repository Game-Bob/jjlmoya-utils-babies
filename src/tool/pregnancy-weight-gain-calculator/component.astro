---
import type { PregnancyWeightGainCalculatorUI } from './entry';
import './pregnancy-weight-gain-calculator.css';

interface Props { ui: PregnancyWeightGainCalculatorUI; }
const { ui } = Astro.props;
---

<div id="pwg-root" class="pwg-shell" data-ui={JSON.stringify(ui)}>
  <section class="pwg-workspace" aria-label={ui.title}>
    <div class="pwg-controls">
      <div class="pwg-warning">
        <span>{ui.educationalWarningTitle}</span>
        <p>{ui.educationalWarningBody}</p>
      </div>

      <div class="pwg-section-head">
        <span>{ui.inputsTitle}</span>
      </div>

      <div class="pwg-field">
        <label>{ui.unitsLabel}</label>
        <div class="pwg-segment" data-control="units">
          <button class="is-active" type="button" data-value="metric">{ui.metricLabel}</button>
          <button type="button" data-value="imperial">{ui.imperialLabel}</button>
        </div>
      </div>

      <div class="pwg-grid">
        <div class="pwg-field">
          <label id="pwg-height-label" for="pwg-height">{ui.heightCmLabel}</label>
          <input id="pwg-height" type="number" min="120" max="220" step="1" value="165" />
        </div>
        <div class="pwg-field">
          <label id="pwg-pre-weight-label" for="pwg-pre-weight">{ui.preWeightKgLabel}</label>
          <input id="pwg-pre-weight" type="number" min="35" max="180" step="0.1" value="62" />
        </div>
        <div class="pwg-field">
          <label id="pwg-current-weight-label" for="pwg-current-weight">{ui.currentWeightKgLabel}</label>
          <input id="pwg-current-weight" type="number" min="35" max="220" step="0.1" value="70" />
        </div>
      </div>

      <div class="pwg-field">
        <div class="pwg-slider-row">
          <label for="pwg-week">{ui.weekLabel}</label>
          <output id="pwg-week-output">24 {ui.weekShortLabel}</output>
        </div>
        <input id="pwg-week" class="pwg-slider" type="range" min="0" max="40" step="1" value="24" />
      </div>

      <div class="pwg-field">
        <label>{ui.pregnancyTypeLabel}</label>
        <div class="pwg-segment" data-control="pregnancyType">
          <button class="is-active" type="button" data-value="singleton">{ui.singletonLabel}</button>
          <button type="button" data-value="twins">{ui.twinsLabel}</button>
        </div>
      </div>
    </div>

    <div class="pwg-results">
      <div class="pwg-kpis">
        <article class="pwg-card">
          <span>{ui.bmiCardTitle}</span>
          <strong id="pwg-bmi">22.8</strong>
          <small id="pwg-category">{ui.categoryNormal}</small>
        </article>
        <article class="pwg-card">
          <span>{ui.currentGainTitle}</span>
          <strong id="pwg-gain">8.0 {ui.kgLabel}</strong>
          <small id="pwg-status">{ui.statusWithin}</small>
        </article>
        <article class="pwg-card">
          <span>{ui.recommendationTitle}</span>
          <strong id="pwg-total-range">11.5-16 {ui.kgLabel}</strong>
          <small>{ui.totalGainSuffix}</small>
        </article>
      </div>

      <div class="pwg-chart-panel">
        <div class="pwg-chart-head">
          <span>{ui.chartTitle}</span>
          <small id="pwg-week-range">4.4-7.5 {ui.kgLabel}</small>
        </div>
        <svg id="pwg-chart" class="pwg-chart" viewBox="0 0 720 360" role="img" aria-label={ui.chartTitle}>
          <defs>
            <linearGradient id="pwg-band-fill" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.34" />
              <stop offset="100%" stop-color="#22c55e" stop-opacity="0.22" />
            </linearGradient>
          </defs>
          <g class="pwg-grid-lines"></g>
          <path id="pwg-band" class="pwg-band" d=""></path>
          <path id="pwg-low-line" class="pwg-low-line" d=""></path>
          <path id="pwg-high-line" class="pwg-high-line" d=""></path>
          <line id="pwg-week-line" class="pwg-week-line" x1="0" x2="0" y1="48" y2="306"></line>
          <circle id="pwg-current-point" class="pwg-current-point" cx="0" cy="0" r="8"></circle>
          <g id="pwg-axis-labels"></g>
        </svg>
        <div class="pwg-legend">
          <span><i class="pwg-swatch pwg-swatch-low"></i>{ui.chartLowLabel}</span>
          <span><i class="pwg-swatch pwg-swatch-high"></i>{ui.chartHighLabel}</span>
          <span><i class="pwg-swatch pwg-swatch-current"></i>{ui.chartCurrentLabel}</span>
        </div>
      </div>

      <div id="pwg-status-card" class="pwg-status-card">
        <strong>{ui.statusWithin}</strong>
        <p>{ui.statusWithinBody}</p>
      </div>

      <div class="pwg-note-grid">
        <div>
          <span>{ui.firstTrimesterLabel}</span>
        </div>
        <div>
          <span id="pwg-weekly-range">{ui.weeklyRangeLabel}</span>
        </div>
      </div>
    </div>
  </section>
</div>

<script is:inline>
  (function() {
    const root = document.getElementById('pwg-root');
    if (!root) return;
    const ui = JSON.parse(root.dataset.ui);
    const storageKey = 'pwg:lastInteraction';
    const state = { units: 'metric', pregnancyType: 'singleton' };
    const singletonGuidelines = [
      { category: 'underweight', bmiMin: 0, bmiMax: 18.49, totalMinKg: 12.5, totalMaxKg: 18, weeklyMinKg: 0.44, weeklyMaxKg: 0.58 },
      { category: 'normal', bmiMin: 18.5, bmiMax: 24.99, totalMinKg: 11.5, totalMaxKg: 16, weeklyMinKg: 0.35, weeklyMaxKg: 0.5 },
      { category: 'overweight', bmiMin: 25, bmiMax: 29.99, totalMinKg: 7, totalMaxKg: 11.5, weeklyMinKg: 0.23, weeklyMaxKg: 0.33 },
      { category: 'obesity', bmiMin: 30, bmiMax: null, totalMinKg: 5, totalMaxKg: 9, weeklyMinKg: 0.17, weeklyMaxKg: 0.27 }
    ];
    const twinTotals = {
      underweight: { totalMinKg: 12.5, totalMaxKg: 18 },
      normal: { totalMinKg: 16.8, totalMaxKg: 24.5 },
      overweight: { totalMinKg: 14.1, totalMaxKg: 22.7 },
      obesity: { totalMinKg: 11.3, totalMaxKg: 19.1 }
    };
    const categoryLabels = {
      underweight: ui.categoryUnderweight,
      normal: ui.categoryNormal,
      overweight: ui.categoryOverweight,
      obesity: ui.categoryObesity
    };

    const el = (id) => document.getElementById(id);
    const readNumber = (id) => parseFloat(el(id).value) || 0;
    const kgToLb = (value) => value * 2.2046226218;
    const lbToKg = (value) => value / 2.2046226218;
    const fmt = (value, digits) => value.toFixed(digits).replace(/\.0$/, '');
    const persistedInputIds = [
      'pwg-height',
      'pwg-pre-weight',
      'pwg-current-weight',
      'pwg-week'
    ];

    function setSegment(control, value) {
      const group = root.querySelector(`.pwg-segment[data-control="${control}"]`);
      if (!group) return;
      group.querySelectorAll('button').forEach((button) => {
        button.classList.toggle('is-active', button.dataset.value === value);
      });
    }

    function cmToIn(value) {
      return value / 2.54;
    }

    function applyUnitLabels() {
      const isImperial = state.units === 'imperial';
      el('pwg-height-label').textContent = isImperial ? ui.heightInLabel : ui.heightCmLabel;
      el('pwg-pre-weight-label').textContent = isImperial ? ui.preWeightLbLabel : ui.preWeightKgLabel;
      el('pwg-current-weight-label').textContent = isImperial ? ui.currentWeightLbLabel : ui.currentWeightKgLabel;

      el('pwg-height').min = isImperial ? '48' : '120';
      el('pwg-height').max = isImperial ? '86' : '220';
      el('pwg-height').step = isImperial ? '0.5' : '1';
      el('pwg-pre-weight').min = isImperial ? '80' : '35';
      el('pwg-pre-weight').max = isImperial ? '400' : '180';
      el('pwg-pre-weight').step = isImperial ? '1' : '0.1';
      el('pwg-current-weight').min = isImperial ? '80' : '35';
      el('pwg-current-weight').max = isImperial ? '500' : '220';
      el('pwg-current-weight').step = isImperial ? '1' : '0.1';
    }

    function convertVisibleInputs(nextUnits) {
      if (state.units === nextUnits) return;
      const height = readNumber('pwg-height');
      const preWeight = readNumber('pwg-pre-weight');
      const currentWeight = readNumber('pwg-current-weight');
      if (nextUnits === 'imperial') {
        el('pwg-height').value = fmt(cmToIn(height), 1);
        el('pwg-pre-weight').value = fmt(kgToLb(preWeight), 0);
        el('pwg-current-weight').value = fmt(kgToLb(currentWeight), 0);
      } else {
        el('pwg-height').value = fmt(height * 2.54, 0);
        el('pwg-pre-weight').value = fmt(lbToKg(preWeight), 1);
        el('pwg-current-weight').value = fmt(lbToKg(currentWeight), 1);
      }
    }

    function saveState() {
      const inputs = {};
      persistedInputIds.forEach((id) => {
        const input = el(id);
        if (input) inputs[id] = input.value;
      });
      localStorage.setItem(storageKey, JSON.stringify({
        units: state.units,
        pregnancyType: state.pregnancyType,
        inputs
      }));
    }

    function loadState() {
      const saved = localStorage.getItem(storageKey);
      if (!saved) return;
      try {
        const parsed = JSON.parse(saved);
        if (parsed.units === 'metric' || parsed.units === 'imperial') {
          state.units = parsed.units;
        }
        if (parsed.pregnancyType === 'singleton' || parsed.pregnancyType === 'twins') {
          state.pregnancyType = parsed.pregnancyType;
        }
        if (parsed.inputs && typeof parsed.inputs === 'object') {
          if (typeof parsed.inputs['pwg-height'] === 'string') {
            persistedInputIds.forEach((id) => {
              const input = el(id);
              const value = parsed.inputs[id];
              if (input && typeof value === 'string') input.value = value;
            });
          } else if (state.units === 'imperial') {
            const feet = parseFloat(parsed.inputs['pwg-height-ft']) || 0;
            const inches = parseFloat(parsed.inputs['pwg-height-in']) || 0;
            el('pwg-height').value = fmt(feet * 12 + inches, 1);
            if (typeof parsed.inputs['pwg-pre-lb'] === 'string') el('pwg-pre-weight').value = parsed.inputs['pwg-pre-lb'];
            if (typeof parsed.inputs['pwg-current-lb'] === 'string') el('pwg-current-weight').value = parsed.inputs['pwg-current-lb'];
            if (typeof parsed.inputs['pwg-week'] === 'string') el('pwg-week').value = parsed.inputs['pwg-week'];
          } else {
            if (typeof parsed.inputs['pwg-height-cm'] === 'string') el('pwg-height').value = parsed.inputs['pwg-height-cm'];
            if (typeof parsed.inputs['pwg-pre-kg'] === 'string') el('pwg-pre-weight').value = parsed.inputs['pwg-pre-kg'];
            if (typeof parsed.inputs['pwg-current-kg'] === 'string') el('pwg-current-weight').value = parsed.inputs['pwg-current-kg'];
            if (typeof parsed.inputs['pwg-week'] === 'string') el('pwg-week').value = parsed.inputs['pwg-week'];
          }
        }
      } catch {
        localStorage.removeItem(storageKey);
      }
      setSegment('units', state.units);
      setSegment('pregnancyType', state.pregnancyType);
      applyUnitLabels();
    }

    function guidelineForBmi(bmi) {
      const base = singletonGuidelines.find((item) => bmi >= item.bmiMin && (item.bmiMax === null || bmi <= item.bmiMax)) || singletonGuidelines[1];
      if (state.pregnancyType === 'singleton') return base;
      const twin = twinTotals[base.category];
      return {
        ...base,
        totalMinKg: twin.totalMinKg,
        totalMaxKg: twin.totalMaxKg,
        weeklyMinKg: Math.max(0, (twin.totalMinKg - 2) / 27),
        weeklyMaxKg: Math.max(0, (twin.totalMaxKg - 0.5) / 27)
      };
    }

    function rangeAtWeek(guideline, week) {
      const safeWeek = Math.min(Math.max(week, 0), 40);
      if (safeWeek <= 13) {
        return { minKg: (0.5 / 13) * safeWeek, maxKg: (2 / 13) * safeWeek };
      }
      const activeWeeks = safeWeek - 13;
      return {
        minKg: Math.min(guideline.totalMinKg, 0.5 + activeWeeks * guideline.weeklyMinKg),
        maxKg: Math.min(guideline.totalMaxKg, 2 + activeWeeks * guideline.weeklyMaxKg)
      };
    }

    function profile() {
      if (state.units === 'imperial') {
        return {
          heightCm: readNumber('pwg-height') * 2.54,
          preKg: lbToKg(readNumber('pwg-pre-weight')),
          currentKg: lbToKg(readNumber('pwg-current-weight'))
        };
      }
      return {
        heightCm: readNumber('pwg-height'),
        preKg: readNumber('pwg-pre-weight'),
        currentKg: readNumber('pwg-current-weight')
      };
    }

    function drawChart(guideline, currentGainKg, week) {
      const svg = el('pwg-chart');
      const grid = svg.querySelector('.pwg-grid-lines');
      const labels = el('pwg-axis-labels');
      const maxY = Math.max(guideline.totalMaxKg + 2, currentGainKg + 3, 10);
      const left = 58;
      const right = 680;
      const top = 44;
      const bottom = 306;
      const x = (w) => left + (w / 40) * (right - left);
      const y = (kg) => bottom - (kg / maxY) * (bottom - top);
      const low = [];
      const high = [];
      for (let w = 0; w <= 40; w += 1) {
        const range = rangeAtWeek(guideline, w);
        low.push([x(w), y(range.minKg)]);
        high.push([x(w), y(range.maxKg)]);
      }
      const pathFrom = (pts) => pts.map((pt, i) => `${i === 0 ? 'M' : 'L'} ${pt[0].toFixed(1)} ${pt[1].toFixed(1)}`).join(' ');
      const bandPath = `${pathFrom(high)} ${low.slice().reverse().map((pt) => `L ${pt[0].toFixed(1)} ${pt[1].toFixed(1)}`).join(' ')} Z`;
      el('pwg-band').setAttribute('d', bandPath);
      el('pwg-low-line').setAttribute('d', pathFrom(low));
      el('pwg-high-line').setAttribute('d', pathFrom(high));
      el('pwg-week-line').setAttribute('x1', x(week));
      el('pwg-week-line').setAttribute('x2', x(week));
      el('pwg-current-point').setAttribute('cx', x(week));
      el('pwg-current-point').setAttribute('cy', y(Math.max(0, currentGainKg)));

      grid.innerHTML = '';
      labels.innerHTML = '';
      [0, 10, 20, 30, 40].forEach((tick) => {
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', x(tick));
        line.setAttribute('x2', x(tick));
        line.setAttribute('y1', top);
        line.setAttribute('y2', bottom);
        grid.appendChild(line);
        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', x(tick));
        label.setAttribute('y', 336);
        label.textContent = tick + ' ' + ui.weekShortLabel;
        labels.appendChild(label);
      });
      [0, Math.round(maxY / 2), Math.round(maxY)].forEach((tick) => {
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', left);
        line.setAttribute('x2', right);
        line.setAttribute('y1', y(tick));
        line.setAttribute('y2', y(tick));
        grid.appendChild(line);
        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', 18);
        label.setAttribute('y', y(tick) + 4);
        label.textContent = fmt(state.units === 'imperial' ? kgToLb(tick) : tick, 0);
        labels.appendChild(label);
      });
    }

    function render() {
      const data = profile();
      const week = parseInt(el('pwg-week').value, 10);
      const heightM = data.heightCm / 100;
      const bmi = heightM > 0 ? data.preKg / (heightM * heightM) : 0;
      const guideline = guidelineForBmi(bmi);
      const gainKg = data.currentKg - data.preKg;
      const range = rangeAtWeek(guideline, week);
      const unitLabel = state.units === 'imperial' ? ui.lbLabel : ui.kgLabel;
      const convert = (kg) => state.units === 'imperial' ? kgToLb(kg) : kg;
      let status = 'within';
      if (gainKg < range.minKg) status = 'below';
      if (gainKg > range.maxKg) status = 'above';

      el('pwg-week-output').textContent = week + ' ' + ui.weekShortLabel;
      el('pwg-bmi').textContent = fmt(bmi, 1);
      el('pwg-category').textContent = categoryLabels[guideline.category];
      el('pwg-gain').textContent = `${fmt(convert(gainKg), 1)} ${unitLabel}`;
      el('pwg-total-range').textContent = `${fmt(convert(guideline.totalMinKg), 1)}-${fmt(convert(guideline.totalMaxKg), 1)} ${unitLabel}`;
      el('pwg-week-range').textContent = `${fmt(convert(range.minKg), 1)}-${fmt(convert(range.maxKg), 1)} ${unitLabel}`;
      el('pwg-weekly-range').textContent = `${ui.weeklyRangeLabel}: ${fmt(convert(guideline.weeklyMinKg), 2)}-${fmt(convert(guideline.weeklyMaxKg), 2)} ${unitLabel} ${ui.perWeekSuffix}`;
      el('pwg-status').textContent = ui[`status${status.charAt(0).toUpperCase() + status.slice(1)}`];
      const statusCard = el('pwg-status-card');
      statusCard.className = `pwg-status-card is-${status}`;
      statusCard.querySelector('strong').textContent = ui[`status${status.charAt(0).toUpperCase() + status.slice(1)}`];
      statusCard.querySelector('p').textContent = ui[`status${status.charAt(0).toUpperCase() + status.slice(1)}Body`];
      drawChart(guideline, gainKg, week);
    }

    root.querySelectorAll('.pwg-segment button').forEach((button) => {
      button.addEventListener('click', () => {
        const group = button.closest('.pwg-segment');
        group.querySelectorAll('button').forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        if (group.dataset.control === 'units') convertVisibleInputs(button.dataset.value);
        state[group.dataset.control] = button.dataset.value;
        applyUnitLabels();
        saveState();
        render();
      });
    });

    root.querySelectorAll('input').forEach((input) => input.addEventListener('input', () => {
      saveState();
      render();
    }));
    loadState();
    render();
  })();
</script>
